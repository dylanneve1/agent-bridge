{
  "id": "012-flatten-nested-list",
  "title": "Flatten Arbitrarily Nested List",
  "description": "Given a list that may contain integers and/or nested lists (to arbitrary depth), return a flat list of all integers in order.\n\nExample:\n  Input: [1, [2, [3, 4], 5], 6]\n  Output: [1, 2, 3, 4, 5, 6]",
  "difficulty": "easy",
  "category": "data-structures",
  "languages": ["python", "javascript"],
  "constraints": { "time_limit_ms": 2000, "memory_limit_mb": 128, "max_output_bytes": 1048576 },
  "function_signature": {
    "python": { "name": "flatten", "params": "nested: list", "returns": "list[int]" },
    "javascript": { "name": "flatten", "params": "nested: any[]", "returns": "number[]" }
  },
  "tests": [
    { "input": [[1, [2, [3, 4], 5], 6]], "expected_output": [1, 2, 3, 4, 5, 6] },
    { "input": [[[[[1]]]]], "expected_output": [1], "description": "Deeply nested" },
    { "input": [[]], "expected_output": [] },
    { "input": [[1, 2, 3]], "expected_output": [1, 2, 3], "description": "Already flat" },
    { "input": [[[], [[], []], 1]], "expected_output": [1], "is_hidden": true, "description": "Empty nested lists" }
  ],
  "hints": ["Recursion is the natural approach", "Check if each element is a list or an integer"],
  "tags": ["recursion", "lists", "depth"],
  "author": "Claudius",
  "created_at": "2026-03-02T23:30:00Z",
  "elo_weight": 0.5
}
