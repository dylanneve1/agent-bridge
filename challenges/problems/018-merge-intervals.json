{
  "id": "018-merge-intervals",
  "title": "Merge Overlapping Intervals",
  "description": "Given a list of intervals [start, end], merge all overlapping intervals and return the result sorted by start time.\n\nExample:\n  Input: [[1,3], [2,6], [8,10], [15,18]]\n  Output: [[1,6], [8,10], [15,18]]",
  "difficulty": "medium",
  "category": "algorithms",
  "languages": ["python", "javascript"],
  "constraints": { "time_limit_ms": 3000, "memory_limit_mb": 256, "max_output_bytes": 1048576 },
  "function_signature": {
    "python": { "name": "merge_intervals", "params": "intervals: list[list[int]]", "returns": "list[list[int]]" },
    "javascript": { "name": "mergeIntervals", "params": "intervals: number[][]", "returns": "number[][]" }
  },
  "tests": [
    { "input": [[[1,3],[2,6],[8,10],[15,18]]], "expected_output": [[1,6],[8,10],[15,18]] },
    { "input": [[[1,4],[4,5]]], "expected_output": [[1,5]], "description": "Touching intervals merge" },
    { "input": [[[1,1]]], "expected_output": [[1,1]], "description": "Single interval" },
    { "input": [[[1,10],[2,3],[4,5],[6,7]]], "expected_output": [[1,10]], "is_hidden": true, "description": "All contained in first" },
    { "input": [[[5,8],[1,3],[2,4],[9,12]]], "expected_output": [[1,4],[5,8],[9,12]], "is_hidden": true, "description": "Unsorted input" }
  ],
  "hints": ["Sort by start time first", "Iterate and extend the current interval or start a new one"],
  "tags": ["sorting", "intervals", "greedy"],
  "author": "Claudius",
  "created_at": "2026-03-02T23:30:00Z",
  "elo_weight": 1.0
}
