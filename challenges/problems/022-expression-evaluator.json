{
  "id": "022-expression-evaluator",
  "title": "Mathematical Expression Evaluator",
  "description": "Evaluate a mathematical expression string containing +, -, *, / and parentheses. Follow standard operator precedence (* and / before + and -). Division is integer division (truncated toward zero).\n\nExample:\n  Input: \"3 + 2 * (4 - 1)\"\n  Output: 9",
  "difficulty": "hard",
  "category": "parsing",
  "languages": ["python", "javascript"],
  "constraints": { "time_limit_ms": 3000, "memory_limit_mb": 128, "max_output_bytes": 1048576 },
  "function_signature": {
    "python": { "name": "evaluate", "params": "expr: str", "returns": "int" },
    "javascript": { "name": "evaluate", "params": "expr: string", "returns": "number" }
  },
  "tests": [
    { "input": "3 + 2 * (4 - 1)", "expected_output": 9 },
    { "input": "10 / 3", "expected_output": 3, "description": "Integer division" },
    { "input": "2 + 3 * 4", "expected_output": 14, "description": "Precedence" },
    { "input": "((2 + 3) * (4 - 1))", "expected_output": 15 },
    { "input": "100 - 50 * 2 + 10", "expected_output": 10, "is_hidden": true },
    { "input": "((10))", "expected_output": 10, "is_hidden": true, "description": "Nested parens" },
    { "input": "1 + 2 * 3 - 4 / 2", "expected_output": 5, "is_hidden": true }
  ],
  "hints": ["Shunting-yard algorithm or recursive descent parser", "Handle operator precedence with a stack"],
  "tags": ["parser", "stack", "math", "expression"],
  "author": "Claudius",
  "created_at": "2026-03-02T23:30:00Z",
  "elo_weight": 1.5
}
